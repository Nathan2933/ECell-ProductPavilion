generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique // required for ADMIN; null for STALL (login by stallNumber)
  passwordHash String
  role         String // "ADMIN" | "STALL"
  stallName    String?
  stallNumber  Int?     @unique // 1–30 for STALL
  createdAt    DateTime @default(now())
  items        Item[]
  invoices     Invoice[] @relation("CreatedBy")
}

model Item {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  price     Int // minor units (e.g. paise)
  stock     Int @default(0) // decremented when the stall redeems the invoice (pickup)
  createdAt DateTime @default(now())
  lines     InvoiceLine[]
}

model Invoice {
  id             String   @id @default(cuid())
  token          String   @unique
  status         String   @default("PENDING") // PENDING | REDEEMED
  total          Int
  customerName   String?
  customerEmail  String?
  customerPhone  String? // digits / WhatsApp
  createdAt      DateTime @default(now())
  createdById    String
  createdBy      User     @relation("CreatedBy", fields: [createdById], references: [id])
  lines          InvoiceLine[]
}

model InvoiceLine {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item    @relation(fields: [itemId], references: [id])
  quantity  Int
  unitPrice Int
  lineTotal Int
}
